# Copy this file to .env and fill in your values.
# Both sentinel_extractor.py and sentinel_restore.py load this file automatically.

# =============================================================================
# AUTHENTICATION
# Used by both the extractor and the restore script.
# =============================================================================
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here

# =============================================================================
# SOURCE — sentinel_extractor.py
# The Sentinel workspace that will be backed up.
# =============================================================================
AZURE_SUBSCRIPTION_ID=your-source-subscription-id-here
AZURE_RESOURCE_GROUP=your-source-resource-group-name-here
AZURE_WORKSPACE_NAME=your-source-log-analytics-workspace-name-here

# Resource group where Logic Apps (playbooks) are deployed (source)
# Leave empty to skip Logic Apps extraction
AZURE_LOGIC_APPS_RESOURCE_GROUP=your-source-logic-apps-resource-group-here

# Resource group where Data Collection Rules are deployed (source)
# Leave empty to skip DCR extraction
AZURE_DCR_RESOURCE_GROUP=your-source-dcr-resource-group-here

# Resource group where Data Collection Endpoints are deployed (source)
# Leave empty to skip DCE extraction
AZURE_DCE_RESOURCE_GROUP=your-source-dce-resource-group-here

# Resource group where Sentinel Workbooks are deployed (source).
# Defaults to AZURE_RESOURCE_GROUP if not set.
# Leave empty (and unset AZURE_RESOURCE_GROUP) to skip Workbooks extraction.
AZURE_WORKBOOKS_RESOURCE_GROUP=your-source-workbooks-resource-group-here

# =============================================================================
# TARGET — sentinel_restore.py
# The Sentinel workspace that content will be restored into.
# =============================================================================
# Full path to the workspace backup folder produced by sentinel_extractor.py.
# This is the folder that contains subfolders like AlertRules/, AutomationRules/, etc.
# Example: ./output/<subscription-id>/<workspace-name>
# Can also be set via --backup-source-dir on the CLI.
AZURE_BACKUP_SOURCE_DIR=./output/your-subscription-id/your-workspace-name

AZURE_TARGET_SUBSCRIPTION_ID=your-target-subscription-id-here
AZURE_TARGET_RESOURCE_GROUP=your-target-resource-group-name-here
AZURE_TARGET_WORKSPACE_NAME=your-target-log-analytics-workspace-name-here

# Resource group where Logic Apps (playbooks) will be restored (target)
# Leave empty to skip Logic Apps restore
AZURE_TARGET_LOGIC_APPS_RESOURCE_GROUP=your-target-logic-apps-resource-group-here

# Resource group where Data Collection Rules will be restored (target)
# Leave empty to skip DCR restore
AZURE_TARGET_DCR_RESOURCE_GROUP=your-target-dcr-resource-group-here

# Resource group where Data Collection Endpoints will be restored (target)
# Leave empty to skip DCE restore
AZURE_TARGET_DCE_RESOURCE_GROUP=your-target-dce-resource-group-here

# Resource group where Sentinel Workbooks will be restored (target)
# Defaults to AZURE_TARGET_RESOURCE_GROUP if not set.
# Leave empty (and unset AZURE_TARGET_RESOURCE_GROUP) to skip Workbooks restore.
AZURE_TARGET_WORKBOOKS_RESOURCE_GROUP=your-target-workbooks-resource-group-here
